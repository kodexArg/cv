---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const contact = [
  { icon: 'fa-solid fa-envelope', label: 'gcavedal@gmail.com', href: 'mailto:gcavedal@gmail.com' },
  { icon: 'fa-solid fa-globe', label: 'cv.kodexarg.com', href: 'https://cv.kodexarg.com/' },
  { icon: 'fa-brands fa-linkedin', label: 'in/gabriel-cavedal', href: 'https://www.linkedin.com/in/gabriel-cavedal/' },
  { icon: 'fa-brands fa-github', label: 'kodexArg', href: 'https://github.com/kodexArg' },
  { icon: 'fa-brands fa-telegram', label: '@KodexArg', href: 'https://t.me/KodexArg' },
  { icon: 'fa-solid fa-location-dot', label: 'Mendoza, Argentina', href: null },
];

const experience = [
  {
    role: 'Technical Lead — IT & Infrastructure',
    company: 'Grupo ALVS · Mendoza, AR',
    dates: '2016 — present',
    bullets: [
      'Lead the group’s IT team across its business units — fuel, retail and more.',
      'Designed and operate the group’s AWS cloud platform — IaC, OIDC-secured CI/CD — running its production helpdesk, payment workflows, B2B fuel portal, institutional sites and IoT telemetry.',
      'Drive AI adoption group-wide: multi-agent orchestration with MCP servers wired into the infrastructure, automated workflows, hands-on AI training for staff.',
      'Architected the multi-site backbone: VPN mesh (MikroTik / IPsec) bridging on-premise sites with AWS.',
    ],
  },
  {
    role: 'Head of Organization & Systems',
    company: 'Mendoza Central Entretenimiento (Casino de Mendoza)',
    dates: '2005 — 2016',
    bullets: [
      'Ran IT end to end for a major casino: virtualized infrastructure, BI dashboards and machine-learning analytics over gaming data.',
    ],
  },
  {
    role: 'Slot Systems Technician',
    company: 'Casino Buenos Aires',
    dates: '2002 — 2005',
    bullets: ['Gaming hardware, networks and systems support — where it all started.'],
  },
];

const projects = [
  {
    name: 'Casino de Mendoza — mission-critical infrastructure',
    stack: 'RHEL clusters · Oracle VM · 700 slot machines',
    text: 'A decade running self-built Linux RHEL server clusters behind 700 networked slot machines — the infrastructure never went down.',
    repo: null,
    live: null,
  },
  {
    name: 'KCBD — grow lab & IoT telemetry',
    stack: 'Raspberry Pi · Django / DRF · Angular',
    text: 'Co-built the cultivation lab and its room-scale sensor network; KCBD Monitor streams its telemetry in production — now headless API + Angular on AWS.',
    repo: 'https://github.com/kodexArg/dj-indoor-monitor',
    live: 'https://kcbd.grupoalvs.com/',
  },
  {
    name: 'Welp — helpdesk & payment workflows',
    stack: 'Django 5 · HTMX · App Runner',
    text: 'Ticketing plus purchase-to-payment workflows, BDD-tested; in production at Grupo ALVS.',
    repo: 'https://github.com/kodexArg/welpdesk',
    live: 'https://helpdesk.grupoalvs.com/',
  },
  {
    name: 'Agentic AI tooling',
    stack: 'Python · MCP · Antigravity SDK',
    text: 'Public MCP servers (terminal, Telegram, content pipelines); autonomous issue-triage agents; private multi-agent orchestration.',
    repo: 'https://github.com/kodexArg/syv-mcp-tools',
    live: null,
  },
  {
    name: 'Eurotrip 2026 — trip planner',
    stack: 'Angular 21 · Cloudflare (Pages · D1 · R2)',
    text: 'Personal travel companion running fully on Cloudflare.',
    repo: 'https://github.com/kodexArg/cf-ng-eurotrip2026',
    live: 'https://eurotrip2026.kodexarg.com/',
  },
  {
    name: 'Sociedad Rural del Oeste Argentino — site & blog',
    stack: 'Astro SSR · Svelte 5 · AWS',
    text: 'Spec-driven full-stack build for the rural society; in production (private repo).',
    repo: null,
    live: 'https://sroa.grupoalvs.com/',
  },
  {
    name: 'Coveris — healthcare capacity-planning SaaS',
    stack: 'Angular 21 · Django / DRF · AWS',
    text: 'Spec-driven SaaS built with a multi-tier AI-agent pipeline; MVP running on AWS.',
    repo: 'https://github.com/kodexArg/kdx-ng-coveris',
    live: null,
  },
  {
    name: 'Subordinación y Valor — agentic world-building',
    stack: 'Creative writing · Godot 4.4 · specs',
    text: 'Story writing and world building with agentic AI: game specs, character kit, Godot client.',
    repo: 'https://github.com/kodexArg/gdt-syv',
    live: null,
  },
];

const skills = [
  {
    icon: 'fa-brands fa-python',
    title: 'Backend',
    items: 'Python · Django / DRF (expert) · FastAPI · PostgreSQL · Redis · pytest',
  },
  {
    icon: 'fa-brands fa-aws',
    title: 'Cloud & DevOps',
    items: 'AWS (end to end) · Cloudflare · Docker · CloudFormation / IaC · CI/CD',
  },
  {
    icon: 'fa-solid fa-network-wired',
    title: 'Infrastructure & IoT',
    items: 'Networking · VPN / IPsec · MikroTik · Raspberry Pi & ESP32 fleets · room-scale sensor networks · video surveillance with AI',
  },
  {
    icon: 'fa-brands fa-linux',
    title: 'Linux SysAdmin',
    items: 'Debian · RHEL · clustering & high availability · Nginx · systemd · self-hosted agentic systems (Hermes Agent · OpenClaw)',
  },
  {
    icon: 'fa-solid fa-code',
    title: 'Full Stack',
    items: 'Angular (CSR & SSR) · Astro · Svelte · HTMX',
  },
  {
    icon: 'fa-solid fa-wand-magic-sparkles',
    title: 'AI & Agents',
    items: 'Multi-agent orchestration · MCP servers & clients · Claude Code · n8n · RAG',
  },
  {
    icon: 'fa-solid fa-people-group',
    title: 'Leadership & Business',
    items: 'Team leadership · Solutions architecture · Business process automation · Vendor & budget management',
  },
  {
    icon: 'fa-solid fa-compass-drafting',
    title: 'Method',
    items: 'Spec-driven development · Contract-first APIs · BDD / TDD · Docs-as-code',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    name: 'Gabriel Cavedal',
    jobTitle: 'AI Solutions Architect & Fractional CTO',
    email: 'mailto:gcavedal@gmail.com',
    url: 'https://cv.kodexarg.com/',
    image: 'https://kodexarg.github.io/cv/gabriel-cavedal.jpg',
    sameAs: [
      'https://www.linkedin.com/in/gabriel-cavedal/',
      'https://github.com/kodexArg',
      'https://t.me/KodexArg',
    ],
    worksFor: { '@type': 'Organization', name: 'Grupo ALVS' },
    knowsAbout: [
      'Agentic AI',
      'Multi-agent Orchestration',
      'Model Context Protocol',
      'Spec-Driven Development',
      'Python',
      'Django',
      'Django REST Framework',
      'AWS',
      'Cloudflare',
      'Linux',
      'IoT',
      'Solutions Architecture',
      'DevOps',
    ],
    knowsLanguage: ['es', 'en'],
    address: { '@type': 'PostalAddress', addressLocality: 'Mendoza', addressCountry: 'AR' },
  },
};
---

<Layout
  lang="en"
  title="Gabriel Cavedal — AI Solutions Architect & Fractional CTO"
  description="Infrastructure & software architect, multi-company technical lead. Spec-driven development with AI agent fleets. Django/DRF expert; production platforms on AWS and Cloudflare. Open to remote consulting."
  ogUrl="https://cv.kodexarg.com/"
>
  <div class="ncv-bg">
    <div class="ncv">
      <header class="masthead">
        <div class="masthead-text">
          <h1>Gabriel Cavedal</h1>
          <p class="headline">AI Solutions Architect · Fractional CTO</p>
          <p class="keywords">Python · Django / DRF · AWS · Cloudflare · Agentic AI · Spec-Driven Development</p>
          <nav class="contact" aria-label="Contact">
            {
              contact.map((c) =>
                c.href ? (
                  <a href={c.href} target={c.href.startsWith('mailto') ? undefined : '_blank'} rel="noopener">
                    <i class={c.icon} aria-hidden="true" />
                    {c.label}
                  </a>
                ) : (
                  <span>
                    <i class={c.icon} aria-hidden="true" />
                    {c.label}
                  </span>
                )
              )
            }
          </nav>
        </div>
        <img class="photo" src={`${base}/gabriel-cavedal.jpg`} alt="Gabriel Cavedal" loading="eager" />
      </header>

      <div class="columns">
        <main>
          <h2><i class="fa-solid fa-user" aria-hidden="true"></i>Profile</h2>
          <p>
            Infrastructure and software architect; multi-company technical lead for 20+ years. I design
            systems end to end — cloud platforms, production web applications, IoT fleets — working
            spec-driven with fleets of AI agents under BDD/TDD discipline. Django/DRF expert. Open to remote
            consulting: architecture reviews, AI adoption scouting, quick wins.
          </p>

          <h2><i class="fa-solid fa-briefcase" aria-hidden="true"></i>Experience</h2>
          {
            experience.map((job) => (
              <section class="job">
                <div class="job-head">
                  <h3>{job.role}</h3>
                  <span class="dates">{job.dates}</span>
                </div>
                <p class="company">{job.company}</p>
                <ul>
                  {job.bullets.map((b) => (
                    <li>{b}</li>
                  ))}
                </ul>
              </section>
            ))
          }

          <h2><i class="fa-solid fa-diagram-project" aria-hidden="true"></i>Selected Work</h2>
          {
            projects.map((p) => (
              <section class="project">
                <div class="job-head">
                  <h3>
                    {p.name}
                    {p.repo && (
                      <a class="proj-link" href={p.repo} target="_blank" rel="noopener" aria-label={`${p.name} on GitHub`}>
                        <i class="fa-brands fa-github" aria-hidden="true" />
                      </a>
                    )}
                    {p.live && (
                      <a class="proj-link" href={p.live} target="_blank" rel="noopener" aria-label={`${p.name} live`}>
                        <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true" />
                      </a>
                    )}
                  </h3>
                  <span class="stack">{p.stack}</span>
                </div>
                <p>{p.text}</p>
              </section>
            ))
          }
        </main>

        <aside>
          <h2><i class="fa-solid fa-layer-group" aria-hidden="true"></i>Core Skills</h2>
          {
            skills.map((g) => (
              <section class="skill-group">
                <h3>
                  <i class={g.icon} aria-hidden="true" />
                  {g.title}
                </h3>
                <p>{g.items}</p>
              </section>
            ))
          }

          <h2><i class="fa-solid fa-language" aria-hidden="true"></i>Languages</h2>
          <p class="side-line">Spanish — native</p>
          <p class="side-line">English — professional working proficiency</p>

          <h2><i class="fa-solid fa-graduation-cap" aria-hidden="true"></i>Education</h2>
          <p class="side-line">Technical school — ENET N°1 «Ing. Pablo Nogués», Mendoza</p>
          <p class="side-line">Electromechanical Engineering (incomplete) — UNSL, San Luis</p>
          <p class="side-line">Graphic Design (incomplete) — Villa Mercedes, San Luis</p>
          <p class="side-line">
        Continuous certification —
        <a href="https://platzi.com/p/gcavedal/" target="_blank" rel="noopener">Platzi</a>: AI &amp; data
        science, backend (Django), cloud &amp; DevOps
          </p>

          <div class="freelance">
            <h3><i class="fa-solid fa-handshake" aria-hidden="true"></i>Freelance &amp; Consulting</h3>
            <p>
              Available for architecture reviews, AI adoption scouting and quick-win engagements.
              Remote-first.
            </p>
          </div>
        </aside>
      </div>
    </div>

    <footer class="ncv-foot">
      <p>
        This page prints to a single A4 —
        <button class="print-btn" onclick="window.print()">print / save as PDF</button>
        &nbsp;·&nbsp;
        <a href={`${base}/full/`}>full legacy CV (Spanish)</a>
      </p>
    </footer>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>

<style is:global>
  /* New one-page CV — all rules prefixed .ncv to stay clear of the legacy /full/ styles. */
  .ncv-bg {
    min-height: 100vh;
    background: linear-gradient(to bottom right, #b8bab7, var(--color-mate-300));
    padding: 2.5rem 1rem 2rem;
    font-family: 'Source Sans Pro', sans-serif;
  }

  .ncv {
    max-width: 1140px;
    margin: 0 auto;
    background: #fff;
    border-radius: 0.5rem;
    box-shadow: 0 10px 25px -5px rgb(55 65 81 / 0.6);
    overflow: hidden;
    color: var(--color-mate-600);
  }

  /* Masthead — deep mate band, light text, photo pops against it. */
  .ncv .masthead {
    display: flex;
    align-items: center;
    gap: 2.25rem;
    padding: 2.25rem 2.25rem 1.8rem;
    background: linear-gradient(to right, var(--color-mate-600), var(--color-mate-700));
  }
  .ncv .masthead-text {
    flex: 1;
    min-width: 0;
  }
  .ncv h1 {
    font-family: 'Oswald', sans-serif;
    font-size: 3.6rem;
    font-weight: 600;
    line-height: 1.05;
    color: var(--color-mate-50);
    margin: 0;
    text-align: left;
    filter: drop-shadow(0 2px 2px rgb(22 26 21 / 0.4));
  }
  .ncv .headline {
    font-family: 'Oswald', sans-serif;
    font-size: 1.5rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-pullover-200);
    margin: 0.5rem 0 0;
    text-align: left;
  }
  .ncv .keywords {
    font-size: 1.28rem;
    color: var(--color-mate-200);
    margin: 0.4rem 0 0;
    text-align: left;
  }
  .ncv .contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1.4rem;
    margin-top: 1.1rem;
    font-size: 1.12rem;
  }
  .ncv .contact a,
  .ncv .contact span {
    color: var(--color-mate-100);
    text-decoration: none;
    transition: color 0.15s ease;
    white-space: nowrap;
  }
  .ncv .contact a:hover {
    color: var(--color-pullover-200);
  }
  .ncv .contact i {
    color: var(--color-pullover-300);
    margin-right: 0.4rem;
  }
  .ncv .photo {
    width: 11rem;
    height: 11rem;
    object-fit: cover;
    border-radius: 0.85rem;
    border: 3px solid var(--color-pullover-300);
    box-shadow: 0 10px 15px -3px rgb(21 18 15 / 0.45);
    flex-shrink: 0;
  }

  /* Columns */
  .ncv .columns {
    display: flex;
    flex-direction: column;
  }
  .ncv .columns > main {
    padding: 0.75rem 2.25rem 2.25rem;
    display: block;
  }
  .ncv .columns > aside {
    background: var(--color-mate-100);
    padding: 0.75rem 2rem 2.25rem;
  }
  @media (min-width: 900px) {
    .ncv .columns {
      flex-direction: row;
      align-items: stretch;
    }
    .ncv .columns > main {
      width: calc(100% * 8 / 13);
    }
    .ncv .columns > aside {
      width: calc(100% * 5 / 13);
    }
  }

  /* Typography overrides (the legacy global.css styles h1-h4/p/section/article at element level) */
  .ncv h2 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-mate-500);
    text-align: left;
    margin: 2rem 0 0.7rem;
    padding-bottom: 0.35rem;
    border-bottom: 2px solid var(--color-pullover-50);
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .ncv h2 i {
    color: var(--color-pullover-400);
    font-size: 1.3rem;
    margin: 0;
  }
  .ncv h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.45rem;
    font-weight: 500;
    color: var(--color-mate-700);
    margin: 0;
  }
  .ncv p {
    font-size: 1.3rem;
    line-height: 1.5;
    text-align: left;
    color: var(--color-mate-600);
    margin: 0;
  }
  .ncv section {
    display: block;
    border: none;
    padding: 0;
  }

  /* Experience & projects */
  .ncv .job,
  .ncv .project {
    margin-top: 1.1rem;
  }
  .ncv .job:first-of-type,
  .ncv .project:first-of-type {
    margin-top: 0.3rem;
  }
  .ncv .job-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .ncv .dates,
  .ncv .stack {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-pullover-400);
    white-space: nowrap;
  }
  .ncv .stack {
    white-space: normal;
    text-align: right;
    font-weight: 400;
  }
  .ncv .company {
    font-size: 1.15rem;
    color: var(--color-mate-500);
    margin-top: 0.1rem;
  }
  .ncv main ul {
    list-style: none;
    margin: 0.4rem 0 0;
    padding: 0;
  }
  .ncv main li {
    font-size: 1.26rem;
    line-height: 1.48;
    color: var(--color-mate-600);
    position: relative;
    padding-left: 1.3rem;
    margin-top: 0.35rem;
  }
  .ncv main li::before {
    content: '▸';
    position: absolute;
    left: 0;
    top: 0.12em;
    font-size: 0.95rem;
    color: var(--color-pullover-300);
  }
  .ncv .proj-link {
    margin-left: 0.55rem;
    color: var(--color-pullover-400);
    text-decoration: none;
    font-size: 1.25rem;
    transition: color 0.15s ease;
  }
  .ncv .proj-link:hover {
    color: var(--color-pullover-300);
  }
  .ncv .proj-link i {
    margin: 0;
  }

  /* Sidebar */
  .ncv .skill-group {
    margin-top: 1rem;
  }
  .ncv .skill-group h3 {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 1.35rem;
  }
  .ncv .skill-group h3 i {
    color: var(--color-pullover-500);
    width: 1.5rem;
    text-align: center;
    margin: 0;
    font-size: 1.15rem;
  }
  .ncv .skill-group p {
    font-size: 1.15rem;
    line-height: 1.5;
    padding-left: 2.15rem;
    margin-top: 0.15rem;
  }
  .ncv .side-line {
    font-size: 1.18rem;
    line-height: 1.5;
    margin-top: 0.3rem;
  }
  .ncv .side-line a {
    color: var(--color-mate-700);
    text-decoration: underline;
    text-decoration-color: var(--color-pullover-200);
    transition: color 0.15s ease;
  }
  .ncv .side-line a:hover {
    color: var(--color-pullover-300);
  }
  .ncv .freelance {
    margin-top: 1.8rem;
    background: rgb(255 255 255 / 0.55);
    border: 1px solid var(--color-pullover-100);
    border-radius: 0.7rem;
    padding: 1.1rem 1.3rem;
  }
  .ncv .freelance h3 {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 1.35rem;
  }
  .ncv .freelance h3 i {
    color: var(--color-pullover-500);
    margin: 0;
    font-size: 1.15rem;
  }
  .ncv .freelance p {
    font-size: 1.15rem;
    line-height: 1.5;
    margin-top: 0.35rem;
  }

  /* Screen-only footer */
  .ncv-foot {
    max-width: 1140px;
    margin: 1.2rem auto 0;
    text-align: center;
  }
  .ncv-foot p {
    font-size: 1.05rem;
    color: var(--color-mate-800);
    font-family: 'Source Sans Pro', sans-serif;
  }
  .ncv-foot a {
    color: var(--color-mate-800);
    text-decoration: underline;
  }
  .ncv-foot .print-btn {
    font-size: 1.05rem;
    color: var(--color-mate-800);
    text-decoration: underline;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
  }
  .ncv-foot a:hover,
  .ncv-foot .print-btn:hover {
    color: var(--color-pullover-500);
  }

  /* Small screens */
  @media (max-width: 640px) {
    .ncv .masthead {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 1.2rem;
      padding: 1.5rem;
    }
    .ncv .photo {
      width: 8rem;
      height: 8rem;
    }
    .ncv h1 {
      font-size: 2.5rem;
    }
    .ncv .keywords {
      font-size: 1.1rem;
    }
    .ncv .contact {
      font-size: 1rem;
    }
    .ncv .columns > main,
    .ncv .columns > aside {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  /* Print: exactly one A4 page */
  @page {
    size: A4;
    margin: 0;
  }
  @media print {
    .ncv-bg {
      padding: 0;
      background: #fff;
      min-height: 0;
    }
    .ncv {
      max-width: 100%;
      width: 100%;
      border-radius: 0;
      box-shadow: none;
    }
    .ncv-foot {
      display: none;
    }
    .ncv .columns {
      flex-direction: row;
    }
    .ncv .columns > main {
      width: calc(100% * 8 / 13);
      padding: 0.15rem 1.4rem 0.5rem;
    }
    .ncv .columns > aside {
      width: calc(100% * 5 / 13);
      padding: 0.15rem 1.2rem 0.5rem;
    }
    .ncv .masthead {
      padding: 0.6rem 1.4rem 0.45rem;
      gap: 1.4rem;
    }
    .ncv h1 {
      font-size: 1.8rem;
      filter: none;
    }
    .ncv .headline {
      font-size: 0.9rem;
      margin-top: 0.15rem;
    }
    .ncv .keywords {
      font-size: 0.76rem;
      margin-top: 0.12rem;
    }
    .ncv .photo {
      width: 4.8rem;
      height: 4.8rem;
      border-width: 2px;
    }
    .ncv h2 {
      font-size: 0.98rem;
      margin-top: 0.45rem;
      margin-bottom: 0.25rem;
      padding-bottom: 0.1rem;
      gap: 0.5rem;
    }
    .ncv h2 i {
      font-size: 0.85rem;
    }
    .ncv h3 {
      font-size: 0.9rem;
    }
    .ncv .project h3 {
      font-size: 0.86rem;
    }
    .ncv p,
    .ncv main li {
      font-size: 0.76rem;
      line-height: 1.24;
    }
    .ncv main ul {
      margin-top: 0.1rem;
