---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const contact = [
  { icon: 'fa-solid fa-envelope', label: 'gcavedal@gmail.com', href: 'mailto:gcavedal@gmail.com' },
  { icon: 'fa-solid fa-globe', label: 'cv.kodexarg.com', href: 'https://cv.kodexarg.com/' },
  { icon: 'fa-brands fa-linkedin', label: 'in/gabriel-cavedal', href: 'https://www.linkedin.com/in/gabriel-cavedal/' },
  { icon: 'fa-brands fa-github', label: 'kodexArg', href: 'https://github.com/kodexArg' },
  { icon: 'fa-brands fa-telegram', label: '@KodexArg', href: 'https://t.me/KodexArg' },
  { icon: 'fa-solid fa-location-dot', label: 'Mendoza, Argentina', href: null },
];

const experience = [
  {
    role: 'Technical Lead — IT & Infraestructura',
    company: 'Grupo ALVS · Mendoza, AR',
    dates: '2016 — presente',
    bullets: [
      'Lidero el equipo de IT del grupo en todas sus unidades de negocio.',
      'Diseñé y opero la plataforma cloud del grupo en AWS, que corre su helpdesk en producción, workflows de pagos, sitios institucionales y telemetría IoT.',
      'Entregué incontables micro-soluciones que conectan la realidad diaria de los empleados con hardware, procesos y otros sistemas.',
      'Impulso la adopción de IA en todo el grupo: orquestación multi-agente con servidores MCP integrados a la infraestructura, workflows automatizados, capacitación hands-on en IA para el personal.',
      'Arquitecté el backbone multi-sitio: malla VPN (MikroTik / IPsec) uniendo los sitios on-premise con AWS.',
    ],
  },
  {
    role: 'Jefe de Organización y Sistemas',
    company: 'Mendoza Central Entretenimiento (Casino de Mendoza)',
    dates: '2005 — 2016',
    bullets: [
      'Diseñé el floorplan del casino de punta a punta — sobre todo sus redes — y construí los clusters de servidores RHEL que sostuvieron toda la infraestructura.',
      'Trabajé codo a codo con Forward System (Unidesa / CIRSA) para implementar su software de juego sobre ese cluster, convirtiéndome en experto en su configuración y parametrización.',
      'Dashboards de BI y analítica con machine learning sobre datos de juego.',
    ],
  },
  {
    role: 'Técnico de Sistemas de Slots',
    company: 'Casino Buenos Aires',
    dates: '2002 — 2005',
    bullets: ['Hardware de juego, redes y soporte de sistemas — donde empezó todo.'],
  },
];

const projects = [
  {
    name: 'Casino de Mendoza',
    stack: 'Clusters RHEL · Oracle VM · 700 slot machines',
    text: 'Una década operando clusters de servidores Linux RHEL construidos a medida detrás de 700 slot machines en red — la infraestructura nunca se cayó.',
    repo: null,
    live: null,
  },
  {
    name: 'KCBD — laboratorio e IoT',
    stack: 'Raspberry Pi · Django / DRF · Angular',
    text: 'Co-construí el laboratorio de cultivo y su red de sensores a escala de sala; KCBD Monitor transmite su telemetría en producción — hoy API headless + Angular sobre AWS.',
    repo: 'https://github.com/kodexArg/dj-indoor-monitor',
    live: 'https://kcbd.grupoalvs.com/',
  },
  {
    name: 'Welp — helpdesk y pagos',
    stack: 'Django 5 · HTMX · App Runner',
    text: 'Ticketing más workflows purchase-to-payment, testeado con BDD; en producción en Grupo ALVS.',
    repo: 'https://github.com/kodexArg/welpdesk',
    live: 'https://helpdesk.grupoalvs.com/',
  },
  {
    name: 'Tooling de IA agéntica',
    stack: 'Python · MCP · Antigravity SDK',
    text: 'Servidores MCP públicos (terminal, Telegram, pipelines de contenido); agentes autónomos de triage de issues; orquestación multi-agente privada.',
    repo: 'https://github.com/kodexArg/syv-mcp-tools',
    live: null,
  },
  {
    name: 'Eurotrip 2026',
    stack: 'Angular 21 · Cloudflare (Pages · D1 · R2)',
    text: 'Compañero de viaje personal corriendo íntegramente sobre Cloudflare.',
    repo: 'https://github.com/kodexArg/cf-ng-eurotrip2026',
    live: 'https://eurotrip2026.kodexarg.com/',
  },
  {
    name: 'Sociedad Rural del Oeste Argentino',
    stack: 'Astro SSR · Svelte 5 · AWS',
    text: 'Desarrollo Full Stack spec-driven para la sociedad rural; en producción (repo privado).',
    repo: null,
    live: 'https://sroa.grupoalvs.com/',
  },
  {
    name: 'Coveris — SaaS de salud',
    stack: 'Angular 21 · Django / DRF · AWS',
    text: 'SaaS spec-driven construido con un pipeline multi-tier de agentes de IA; MVP corriendo en AWS.',
    repo: 'https://github.com/kodexArg/kdx-ng-coveris',
    live: null,
  },
  {
    name: 'Subordinación y Valor',
    stack: 'Godot 4.4 · world building · multi-agente',
    text: 'Mi aventura en el desarrollo de videojuegos, y el sandbox donde aterriza primero cada nueva tecnología — un universo rico de world building llevado como experimento multi-agente.',
    repo: 'https://github.com/kodexArg/gdt-syv',
    live: 'https://kodexarg.github.io/syv/',
  },
];

const skills = [
  {
    icon: 'fa-brands fa-python',
    title: 'Backend',
    items: 'Python · Django / DRF (experto) · FastAPI · PostgreSQL · Redis · pytest',
  },
  {
    icon: 'fa-brands fa-aws',
    title: 'Cloud & DevOps',
    items: 'AWS (end to end) · Cloudflare · Docker · CloudFormation / IaC · CI/CD',
  },
  {
    icon: 'fa-solid fa-network-wired',
    title: 'Infraestructura & IoT',
    items: 'Networking · VPN / IPsec · MikroTik · flotas de Raspberry Pi y ESP32 · redes de sensores a escala de sala · videovigilancia con IA',
  },
  {
    icon: 'fa-brands fa-linux',
    title: 'Linux SysAdmin',
    items: 'Debian · RHEL · clustering y alta disponibilidad · Nginx · systemd · sistemas agénticos self-hosted (Hermes Agent · OpenClaw)',
  },
  {
    icon: 'fa-solid fa-code',
    title: 'Full Stack',
    items: 'Angular (CSR & SSR) · Astro · Svelte · HTMX',
  },
  {
    icon: 'fa-solid fa-wand-magic-sparkles',
    title: 'IA & Agentes',
    items: 'Orquestación multi-agente · Servidores y clientes MCP · Claude Code · n8n · RAG',
  },
  {
    icon: 'fa-solid fa-people-group',
    title: 'Liderazgo & Negocio',
    items: 'Liderazgo de equipos · Arquitectura de soluciones · Automatización de procesos de negocio · Gestión de proveedores y presupuesto',
  },
  {
    icon: 'fa-solid fa-compass-drafting',
    title: 'Método',
    items: 'Spec-driven development · APIs contract-first · BDD / TDD · Docs-as-code',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  inLanguage: 'es',
  mainEntity: {
    '@type': 'Person',
    name: 'Gabriel Cavedal',
    jobTitle: 'AI Solutions Architect & Fractional CTO',
    email: 'mailto:gcavedal@gmail.com',
    url: 'https://cv.kodexarg.com/es/',
    image: 'https://kodexarg.github.io/cv/gabriel-cavedal.jpg',
    sameAs: [
      'https://www.linkedin.com/in/gabriel-cavedal/',
      'https://github.com/kodexArg',
      'https://t.me/KodexArg',
    ],
    worksFor: { '@type': 'Organization', name: 'Grupo ALVS' },
    knowsAbout: [
      'Agentic AI',
      'Multi-agent Orchestration',
      'Model Context Protocol',
      'Spec-Driven Development',
      'Python',
      'Django',
      'Django REST Framework',
      'AWS',
      'Cloudflare',
      'Linux',
      'IoT',
      'Solutions Architecture',
      'DevOps',
    ],
    knowsLanguage: ['es', 'en'],
    address: { '@type': 'PostalAddress', addressLocality: 'Mendoza', addressCountry: 'AR' },
  },
};
---

<Layout
  lang="es"
  title="Gabriel Cavedal — AI Solutions Architect & Fractional CTO"
  description="Arquitecto de infraestructura y software, líder técnico multi-empresa. Spec-driven development con flotas de agentes de IA. Experto en Django/DRF; plataformas en producción sobre AWS y Cloudflare. Disponible para consultoría remota."
  ogUrl="https://cv.kodexarg.com/es/"
>
  <div class="ncv-bg">
    <div class="ncv">
      <header class="masthead">
        <div class="masthead-text">
          <h1>Gabriel Cavedal</h1>
          <p class="headline">AI Solutions Architect · Fractional CTO</p>
          <p class="keywords">Python · Django / DRF · AWS · Cloudflare · IA agéntica</p>
          <nav class="contact" aria-label="Contacto">
            {
              contact.map((c) =>
                c.href ? (
                  <a href={c.href} target={c.href.startsWith('mailto') ? undefined : '_blank'} rel="noopener">
                    <i class={c.icon} aria-hidden="true" />
                    {c.label}
                  </a>
                ) : (
                  <span>
                    <i class={c.icon} aria-hidden="true" />
                    {c.label}
                  </span>
                )
              )
            }
          </nav>
        </div>
        <img class="photo" src={`${base}/gabriel-cavedal.jpg`} alt="Gabriel Cavedal" loading="eager" />
      </header>

      <div class="columns">
        <main>
          <h2><i class="fa-solid fa-user" aria-hidden="true"></i>Perfil</h2>
          <p>
            Arquitecto de infraestructura y software; líder técnico multi-empresa desde hace más de 20
            años. Diseño sistemas de punta a punta — plataformas cloud, aplicaciones web en producción,
            flotas IoT — trabajando, y formando equipos, en spec-driven development con flotas de agentes
            de IA bajo disciplina BDD/TDD. Experto en Django/DRF. Disponible para consultoría remota:
            architecture reviews, scouting de adopción de IA, quick wins.
          </p>

          <h2><i class="fa-solid fa-briefcase" aria-hidden="true"></i>Experiencia</h2>
          {
            experience.map((job) => (
              <section class="job">
                <div class="job-head">
                  <h3>{job.role}</h3>
                  <span class="dates">{job.dates}</span>
                </div>
                <p class="company">{job.company}</p>
                <ul>
                  {job.bullets.map((b) => (
                    <li>{b}</li>
                  ))}
                </ul>
              </section>
            ))
          }

          <h2><i class="fa-solid fa-diagram-project" aria-hidden="true"></i>Proyectos destacados</h2>
          {
            projects.map((p) => (
              <section class="project">
                <div class="job-head">
                  <h3>
                    {p.name}
                    {p.repo && (
                      <a class="proj-link" href={p.repo} target="_blank" rel="noopener" aria-label={`${p.name} en GitHub`}>
                        <i class="fa-brands fa-github" aria-hidden="true" />
                      </a>
                    )}
                    {p.live && (
                      <a class="proj-link" href={p.live} target="_blank" rel="noopener" aria-label={`${p.name} en vivo`}>
                        <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true" />
                      </a>
                    )}
                  </h3>
                  <span class="stack">{p.stack}</span>
                </div>
                <p>{p.text}</p>
              </section>
            ))
          }
        </main>

        <aside>
          <h2><i class="fa-solid fa-layer-group" aria-hidden="true"></i>Core Skills</h2>
          {
            skills.map((g) => (
              <section class="skill-group">
                <h3>
                  <i class={g.icon} aria-hidden="true" />
                  {g.title}
                </h3>
                <p>{g.items}</p>
              </section>
            ))
          }

          <h2><i class="fa-solid fa-language" aria-hidden="true"></i>Idiomas</h2>
          <p class="side-line">Español — nativo</p>
          <p class="side-line">Inglés — competencia profesional</p>

          <h2><i class="fa-solid fa-graduation-cap" aria-hidden="true"></i>Educación</h2>
          <p class="side-line">Escuela técnica — ENET N°1 «Ing. Pablo Nogués», Mendoza</p>
          <p class="side-line">Ingeniería Electromecánica (incompleta) — UNSL, San Luis</p>
          <p class="side-line">Diseño Gráfico (incompleto) — Villa Mercedes, San Luis</p>
          <p class="side-line">
        Certificación continua —
        <a href="https://platzi.com/p/gcavedal/" target="_blank" rel="noopener">Platzi</a>: IA &amp; data
        science, backend (Django), cloud &amp; DevOps
          </p>

          <div class="freelance">
            <h3><i class="fa-solid fa-handshake" aria-hidden="true"></i>Freelance &amp; Consultoría</h3>
            <p>
              Disponible para architecture reviews, scouting de adopción de IA y proyectos quick-win.
              Remote-first.
            </p>
          </div>
        </aside>
      </div>
    </div>

    <footer class="ncv-foot">
      <p>
        Esta página imprime en un único A4 —
        <button class="print-btn" onclick="window.print()">imprimir / guardar como PDF</button>
        &nbsp;·&nbsp;
        <a href={`${base}/`}>English version</a>
        &nbsp;·&nbsp;
        <a href={`${base}/full/`}>CV legacy completo (castellano)</a>
      </p>
    </footer>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>

<style is:global>
  /* New one-page CV — all rules prefixed .ncv to stay clear of the legacy /full/ styles. */
  .ncv-bg {
    min-height: 100vh;
    background: linear-gradient(to bottom right, #b8bab7, var(--color-mate-300));
    padding: 2.5rem 1rem 2rem;
    font-family: 'Source Sans Pro', sans-serif;
  }

  .ncv {
    max-width: 1140px;
    margin: 0 auto;
    background: #fff;
    border-radius: 0.5rem;
    box-shadow: 0 10px 25px -5px rgb(55 65 81 / 0.6);
    overflow: hidden;
    color: var(--color-mate-600);
  }

  /* Masthead — deep mate band, light text, photo pops against it. */
  .ncv .masthead {
    display: flex;
    align-items: center;
    gap: 2.25rem;
    padding: 2.25rem 2.25rem 1.8rem;
    background: linear-gradient(to right, var(--color-mate-600), var(--color-mate-700));
  }
  .ncv .masthead-text {
    flex: 1;
    min-width: 0;
  }
  .ncv h1 {
    font-family: 'Oswald', sans-serif;
    font-size: 3.6rem;
    font-weight: 600;
    line-height: 1.05;
    color: var(--color-mate-50);
    margin: 0;
    text-align: left;
    filter: drop-shadow(0 2px 2px rgb(22 26 21 / 0.4));
  }
  .ncv .headline {
    font-family: 'Oswald', sans-serif;
    font-size: 1.5rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-pullover-200);
    margin: 0.5rem 0 0;
    text-align: left;
  }
  .ncv .keywords {
    font-size: 1.28rem;
    color: var(--color-mate-200);
    margin: 0.4rem 0 0;
    text-align: left;
  }
  .ncv .contact {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(2, auto);
    justify-content: start;
    gap: 0.45rem 1.8rem;
    margin-top: 1.1rem;
    font-size: 1.12rem;
  }
  .ncv .contact a,
  .ncv .contact span {
    color: var(--color-mate-100);
    text-decoration: none;
    transition: color 0.15s ease;
    white-space: nowrap;
  }
  .ncv .contact a:hover {
    color: var(--color-pullover-200);
  }
  .ncv .contact i {
    color: var(--color-pullover-300);
    margin-right: 0.4rem;
  }
  .ncv .photo {
    width: 11rem;
    height: 11rem;
    object-fit: cover;
    border-radius: 0.85rem;
    border: 3px solid var(--color-pullover-300);
    box-shadow: 0 10px 15px -3px rgb(21 18 15 / 0.45);
    flex-shrink: 0;
  }

  /* Columns */
  .ncv .columns {
    display: flex;
    flex-direction: column;
  }
  .ncv .columns > main {
    padding: 0.75rem 2.25rem 2.25rem;
    display: block;
  }
  .ncv .columns > aside {
    background: var(--color-mate-100);
    padding: 0.75rem 2rem 2.25rem;
  }
  @media (min-width: 900px) {
    .ncv .columns {
      flex-direction: row;
      align-items: stretch;
    }
    .ncv .columns > main {
      width: calc(100% * 8 / 13);
    }
    .ncv .columns > aside {
      width: calc(100% * 5 / 13);
    }
  }

  /* Typography overrides (the legacy global.css styles h1-h4/p/section/article at element level) */
  .ncv h2 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-mate-500);
    text-align: left;
    margin: 2rem 0 0.7rem;
    padding-bottom: 0.35rem;
    border-bottom: 2px solid var(--color-pullover-50);
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .ncv h2 i {
    color: var(--color-pullover-400);
    font-size: 1.3rem;
    margin: 0;
  }
  .ncv h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.45rem;
    font-weight: 500;
    color: var(--color-mate-700);
    margin: 0;
  }
  .ncv p {
    font-size: 1.3rem;
    line-height: 1.5;
    text-align: left;
    color: var(--color-mate-600);
    margin: 0;
  }
  .ncv main p,
  .ncv main li {
    text-align: justify;
    hyphens: auto;
  }
  .ncv main .company {
    text-align: left;
  }
  .ncv section {
    display: block;
    border: none;
    padding: 0;
  }

  /* Experience & projects */
  .ncv .job,
  .ncv .project {
    margin-top: 1.1rem;
  }
  .ncv .job:first-of-type,
  .ncv .project:first-of-type {
    margin-top: 0.3rem;
  }
  .ncv .job-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .ncv .dates,
  .ncv .stack {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-pullover-400);
    white-space: nowrap;
  }
  .ncv .stack {
    white-space: normal;
    text-align: right;
    font-weight: 400;
  }
  .ncv .company {
    font-size: 1.15rem;
    color: var(--color-mate-500);
    margin-top: 0.1rem;
  }
  .ncv main ul {
    list-style: none;
    margin: 0.4rem 0 0;
    padding: 0;
  }
  .ncv main li {
    font-size: 1.26rem;
    line-height: 1.48;
    color: var(--color-mate-600);
    position: relative;
    padding-left: 1.3rem;
    margin-top: 0.35rem;
  }
  .ncv main li::before {
    content: '▸';
    position: absolute;
    left: 0;
    top: 0.12em;
    font-size: 0.95rem;
    color: var(--color-pullover-300);
  }
  .ncv .proj-link {
    margin-left: 0.55rem;
    color: var(--color-pullover-400);
    text-decoration: none;
    font-size: 1.25rem;
    transition: color 0.15s ease;
  }
  .ncv .proj-link:hover {
    color: var(--color-pullover-300);
  }
  .ncv .proj-link i {
    margin: 0;
  }

  /* Sidebar */
  .ncv .skill-group {
    margin-top: 1rem;
  }
  .ncv .skill-group h3 {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 1.35rem;
  }
  .ncv .skill-group h3 i {
    color: var(--color-pullover-500);
    width: 1.5rem;
    text-align: center;
    margin: 0;
    font-size: 1.15rem;
  }
  .ncv .skill-group p {
    font-size: 1.15rem;
    line-height: 1.5;
    padding-left: 2.15rem;
    margin-top: 0.15rem;
  }
  .ncv .side-line {
    font-size: 1.18rem;
    line-height: 1.5;
    margin-top: 0.3rem;
  }
  .ncv .side-line a {
    color: var(--color-mate-700);
    text-decoration: underline;
    text-decoration-color: var(--color-pullover-200);
    transition: color 0.15s ease;
  }
  .ncv .side-line a:hover {
    color: var(--color-pullover-300);
  }
  .ncv .freelance {
    margin-top: 1.8rem;
    background: rgb(255 255 255 / 0.55);
    border: 1px solid var(--color-pullover-100);
    border-radius: 0.7rem;
    padding: 1.1rem 1.3rem;
  }
  .ncv .freelance h3 {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 1.35rem;
  }
  .ncv .freelance h3 i {
    color: var(--color-pullover-500);
    margin: 0;
    font-size: 1.15rem;
  }
  .ncv .freelance p {
    font-size: 1.15rem;
    line-height: 1.5;
    margin-top: 0.35rem;
  }

  /* Screen-only footer */
  .ncv-foot {
    max-width: 1140px;
    margin: 1.2rem auto 0;
    text-align: center;
  }
  .ncv-foot p {
    font-size: 1.05rem;
    color: var(--color-mate-800);
    font-family: 'Source Sans Pro', sans-serif;
  }
  .ncv-foot a {
    color: var(--color-mate-800);
    text-decoration: underline;
  }
  .ncv-foot .print-btn {
    font-size: 1.05rem;
    color: var(--color-mate-800);
    text-decoration: underline;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
  }
  .ncv-foot a:hover,
  .ncv-foot .print-btn:hover {
    color: var(--color-pullover-500);
  }

  /* Small screens */
  @media (max-width: 640px) {
    .ncv .masthead {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 1.2rem;
      padding: 1.5rem;
    }
    .ncv .photo {
      width: 8rem;
      height: 8rem;
    }
    .ncv h1 {
      font-size: 2.5rem;
    }
    .ncv .keywords {
      font-size: 1.1rem;
    }
    .ncv .contact {
      font-size: 1rem;
      grid-template-rows: repeat(3, auto);
    }
    .ncv .columns > main,
    .ncv .columns > aside {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  /* Print: exactly one A4 page */
  @page {
    size: A4;
    margin: 0;
  }
  @media print {
    .ncv-bg {
